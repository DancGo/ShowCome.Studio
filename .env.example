# =============================================================================
#  兽可梦 ShowCome — 环境变量配置模板
#  复制为 .env 并修改；首次部署也可通过 /admin 初始化向导自动生成
# =============================================================================

# ── 服务端口 ──
PORT=3000

# ── MySQL 数据库 ──
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=showcomefu
DB_USER=showcome
DB_PASS=你的数据库密码

# ── JWT 认证 ──
JWT_SECRET=替换为64位随机字符串
JWT_EXPIRES=12h

# ── 前端域名（CORS 用） ──
FRONTEND_URL=https://你的域名.com

# ── 阿里云 OSS 对象存储 ──
OSS_REGION=oss-cn-haikou
OSS_BUCKET=showcomefu
OSS_ACCESS_KEY_ID=你的AccessKeyId
OSS_ACCESS_KEY_SECRET=你的AccessKeySecret
OSS_ENDPOINT=https://oss-cn-haikou.aliyuncs.com
OSS_CDN_DOMAIN=

# ── 运行环境 ──
NODE_ENV=production
